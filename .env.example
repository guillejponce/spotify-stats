# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Spotify — Developer Dashboard app
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Redirect URI MUST match Spotify Dashboard exactly (scheme, host, port, path, no trailing slash).
#
# Spotify (2025+): redirect URIs with hostname "localhost" are rejected ("Insecure redirect URI").
# For local dev use the loopback IP with HTTP — see:
# https://developer.spotify.com/documentation/web-api/tutorials/migration-insecure-redirect-uri
#
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Open the site in the browser at the SAME URL as NEXT_PUBLIC_APP_URL (127.0.0.1, not "localhost")

# Cron: GET /api/spotify/sync-recent inserts recent plays. In prod send Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
